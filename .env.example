# ============================================
# ENVIRONMENT VARIABLES - Copy to .env.local
# ============================================

# SUPABASE Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Sheets Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",...}
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMKUVfvxxxxxx
GOOGLE_SHEETS_TAB_INPUT=0
GOOGLE_SHEETS_TAB_OUTPUT=1

# TikTok API Configuration (TikApi.io)
TIKAPI_KEY=your-tikapi-key-here
TIKAPI_BASE_URL=https://api.tiktok.com/v1
TIKAPI_TIMEOUT_MS=15000

# Application Configuration
WEBHOOK_SECRET_KEY=your-random-secret-key-minimum-32-characters
MAX_VIDEOS_PER_SYNC=50
MIN_SYNC_INTERVAL_MINUTES=60
API_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# Logging & Debugging
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info

# Optional: Notifications
ALERT_EMAIL=your-email@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
